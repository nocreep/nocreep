{
  "name": "nocreep",
  "version": "0.3.0",
  "description": "opencode tool plugin for pruning previous tool outputs from future model context, avoiding context creep.",
  "author": {
    "name": "Linus Schlumberger",
    "email": "l@mll.one"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nocreep/nocreep"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nocreep": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "start": "npm run build && node ./dist/cli.js",
    "stats": "npm run start -- --stats"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0",
    "@opencode-ai/sdk": ">=1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.14",
    "@opencode-ai/sdk": "^1.17.14",
    "@types/node": "^22.13.9",
    "prettier": "^3.6.2",
    "typescript": "^5.8.2"
  }
}
